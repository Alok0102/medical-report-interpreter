# Medical Report Interpreter Configuration
# Set to 'true' to use live Gemini API. If 'false', runs in mock simulation mode.
USE_GEMINI_API=false

# Your Gemini API Key (Required if USE_GEMINI_API=true)
GEMINI_API_KEY=your_gemini_api_key_here

# MCP Server Settings
MCP_SERVER_URL=http://localhost:8001/mcp
